# Local development database path for the Tauri app.
DATABASE_URL="file:./tauri/app.db"

# Public key used by the Tauri updater to verify signed releases.
# Generate this from your updater/signing setup and paste the public key value here.
TAURI_UPDATER_PUBLIC_KEY="PASTE_YOUR_TAURI_UPDATER_PUBLIC_KEY_HERE"

# CI/release only (set these in GitHub Actions secrets, not in local .env files):
# TAURI_SIGNING_PRIVATE_KEY=""
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""